{
  "manifest_version": 3,
  "name": "WithinOrbit",
  "version": "1.0",
  "description": "Focus timer with YouTube pause feature",

  "permissions": [
    "alarms",
    "tabs",
    "notifications",
    "storage"
  ],

  "host_permissions": [
    "*://*.youtube.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}